{
  "language": "typescript",
  "packageManager": "npm",
  "commands": {
    "typecheck": "YOUR_TYPECHECK_CMD",
    "lint": "YOUR_LINT_CMD",
    "test": "YOUR_TEST_CMD",
    "build": "YOUR_BUILD_CMD"
  },
  "security": {
    "secretScan": "core/hooks/scripts/secret-scan.sh",
    "sast": "",
    "depAudit": "",
    "review": {
      "apiDir": "src/app/api",
      "tenantParam": "clientId|tenantId|orgId",
      "authSignals": "getUser|requireAuth|getServerSession|verifySessionCookie|session|createHmac|timingSafeEqual",
      "cronCheck": "CRON_SECRET",
      "publicEnvPrefix": "NEXT_PUBLIC_",
      "publicEnvAllow": "FIREBASE"
    }
  },
  "ratchets": {
    "deadCode": "",
    "structural": "",
    "baselineDir": ".sentrux/"
  },
  "gates": {
    "preCommit": { "secretScan": "blocking" },
    "prePush": {
      "blocking": true,
      "steps": ["typecheck", "lint", "test"]
    },
    "push": "operator-only",
    "closeProtocol": "blocking"
  },
  "environment": {
    "forbiddenCommands": [
      {
        "pattern": "(^|[;&|]\\s*)(npx\\s+)?eslint\\b",
        "fix": "Global ESLint fails without eslint.config here. Use: YOUR_LINT_CMD"
      }
    ]
  },
  "paths": {
    "source": ["src/**"],
    "codeExtensions": [".ts", ".tsx"]
  }
}
