{
  "language": "typescript",
  "packageManager": "npm",
  "commands": {
    "typecheck": "npx tsc --noEmit",
    "lint": "npm run lint",
    "test": "npm run test:unit",
    "testAlerts": "npm run test:alerts",
    "design": "npm run check:design",
    "cronDoc": "npm run check:cron-doc",
    "build": "npm run build"
  },
  "security": {
    "secretScan": "bash scripts/check-no-secrets.sh",
    "sast": "",
    "depAudit": "",
    "review": {
      "apiDir": "src/app/api",
      "tenantParam": "clientId",
      "authSignals": "requireClientAccess|getAuthenticatedUser|requirePortalSession|requireActivePortalClient|validateCronSecret|isAllowedMcpEmail|verifySessionCookie|cookies\\.get|createHmac|timingSafeEqual|signed_request",
      "cronCheck": "validateCronSecret",
      "publicEnvPrefix": "NEXT_PUBLIC_",
      "publicEnvAllow": "FIREBASE"
    }
  },
  "ratchets": {
    "deadCode": "npm run check:dead-code",
    "structural": "sentrux gate",
    "baselineDir": ".sentrux/"
  },
  "gates": {
    "preCommit": { "secretScan": "blocking" },
    "prePush": {
      "blocking": true,
      "steps": ["typecheck", "lint", "testAlerts", "test", "design", "cronDoc", "structural"]
    },
    "push": "operator-only",
    "closeProtocol": "blocking"
  },
  "environment": {
    "forbiddenCommands": [
      {
        "pattern": "(^|[;&|]\\s*)(npx\\s+)?eslint\\b",
        "fix": "eslint directo falla aca (ESLint 9 global sin eslint.config). Usa: npm run lint | fix: npx next lint --fix"
      },
      {
        "pattern": "\\bfirebase\\s+(login|deploy|firestore|use)\\b",
        "fix": "El CLI de firebase pide login interactivo y muere headless. Usa la via service-account: npx tsx --require ./scripts/load-env.cjs scripts/..."
      },
      {
        "pattern": "(^|[;&|(]\\s*)jq\\b|\\|\\s*jq\\b",
        "fix": "jq no esta instalado. Usa: node -e con JSON.parse"
      },
      {
        "pattern": "\\b(Select-Object|ForEach-Object|Get-ChildItem|Get-Content|Write-Host|Select-String|Test-Path)\\b|\\$env:",
        "fix": "Eso es sintaxis PowerShell dentro del tool Bash. Usa el tool PowerShell, o sintaxis POSIX en Bash."
      }
    ]
  },
  "context": {
    "filterVerbose": ["npm run test:unit", "npm run test:alerts", "npm run test:pre-push"]
  },
  "paths": {
    "source": ["src/**"],
    "codeExtensions": [".ts", ".tsx"]
  }
}
