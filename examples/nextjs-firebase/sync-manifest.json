    "rules/ci-zero-failure.md": ".claude/rules/ci-zero-failure.md",
    "rules/folder-organization.md": ".claude/rules/folder-organization.md",
    "rules/windows-environment.md": ".claude/rules/windows-environment.md",
    "rules/ui-delivery-checklist.md": ".claude/rules/ui-delivery-checklist.md",
    "rules/incident-triage.md": ".claude/rules/incident-triage.md",
    "settings.json": ".claude/settings.json",
    "scripts/pre-push-quality-guard.py": "scripts/pre-push-quality-guard.py",
    "scripts/pre-bash-canonical-guard.py": "scripts/pre-bash-canonical-guard.py",
    "scripts/stop-dead-code-guard.py": "scripts/stop-dead-code-guard.py",
    "scripts/stop-design-guard.py": "scripts/stop-design-guard.py",
    "scripts/stop-dirty-tree-guard.py": "scripts/stop-dirty-tree-guard.py",
