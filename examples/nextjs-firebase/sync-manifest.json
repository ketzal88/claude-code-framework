    "scripts/check-design-baseline.js": "scripts/check-design-baseline.js",
    "scripts/check-cron-doc-sync.js": "scripts/check-cron-doc-sync.js",
    "scripts/check-error-reporting.js": "scripts/check-error-reporting.js",
    "scripts/check-no-new-any.js": "scripts/check-no-new-any.js",
    "scripts/check-no-secrets.sh": "scripts/check-no-secrets.sh",
    "scripts/ops/dev-up.mjs": "scripts/ops/dev-up.mjs"
  },
  "replacements": [
    { "pattern": "Worker Brain", "replace": "ExampleApp" },
    { "pattern": "WorkerBrain", "replace": "ExampleApp" },
    { "pattern": "worker-brain", "replace": "nextjs-firebase" },
    { "pattern": "brain\\.worker\\.ar", "replace": "app.example.com" },
    { "pattern": "@worker\\.ar", "replace": "@example.com" },
    { "pattern": "ketzal88", "replace": "your-org" },
    { "pattern": "\\bGabriel\\b", "replace": "el operador" },
    { "pattern": "\\bSebasti[aá]n\\b", "replace": "el operador" },
    { "pattern": "\\bBlunua\\b", "replace": "ClientA" },
    { "pattern": "\\bPaia\\b", "replace": "ClientB" },
    { "pattern": "\\belepants\\b", "replace": "ClientC" },
    { "pattern": "\\bPriscila\\b", "replace": "OwnerName" },
    { "pattern": "\\bCami\\b", "replace": "SpecialistName" },
    { "pattern": "C0[A-Z0-9]{8,}", "replace": "C0XXXXXXXXX" }
  ],
  "leakCheck": [
    "Worker Brain", "worker-brain", "brain\\.worker", "ketzal88",
    "\\bGabriel\\b", "Blunua", "\\bPaia\\b", "@worker\\.ar"
  ]
}
