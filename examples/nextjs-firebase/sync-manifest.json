    "rules/firestore-conventions.md": ".claude/rules/firestore-conventions.md",
    "rules/alert-engine-pattern.md": ".claude/rules/alert-engine-pattern.md",
    "rules/cron-security.md": ".claude/rules/cron-security.md",
